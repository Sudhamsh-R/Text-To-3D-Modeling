# Server
PORT=3000

# RapidAPI — AI Text to Image Generator
# https://rapidapi.com/bussinesonline250/api/ai-text-to-image-generator-api
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=ai-text-to-image-generator-api.p.rapidapi.com
# Primary endpoint (check RapidAPI playground if this changes)
RAPIDAPI_PATH=/3D
# Fallback endpoints, comma-separated
RAPIDAPI_FALLBACK_PATHS=/realistic

# Meshy — Image to 3D
# https://www.meshy.ai/
MESHY_API_KEY=your_meshy_api_key_here
